fn update_default_descriptions(days: &mut Vec<ChurchDay>) {
    let mut advent_counter = 1;
    let mut ordinary_counter = 1;
    let mut lent_counter = 0;
    let mut easter_counter = 1;

    for day in days {
        let weekday = day.date.weekday();
        if day.description.is_empty() {
            if weekday == Weekday::Sun {
                match day.season {
                    Season::Lent => {
                        lent_counter += 1;
                        day.description = format!(
                            "{}{} Sunday of {}",
                            lent_counter,
                            ordinal_suffix(lent_counter),
                            "Lent"
                        );
                    }
                    Season::Advent => {
                        advent_counter += 1;
                        day.description = format!(
                            "{}{} Sunday of {}",
                            advent_counter,
                            ordinal_suffix(advent_counter),
                            "Advent"
                        );
                    }
                    Season::Easter => {
                        easter_counter += 1;
                        day.description = format!(
                            "{}{} Sunday of {}",
                            easter_counter,
                            ordinal_suffix(easter_counter),
                            "Easter"
                        );
                    }
                    Season::Christmas => {
                        day.description =
                            String::from("The Holy Family of Jesus, Mary, and Joseph");
                    }
                    Season::OrdinaryTime => {
                        ordinary_counter += 1;
                        day.description = format!(
                            "{}{} Sunday of {}",
                            ordinary_counter,
                            ordinal_suffix(ordinary_counter),
                            "Ordinary Time"
                        );
                    }
                    _ => (),
                }
            } else {
                let day_string = match weekday {
                    Weekday::Sun => "Sunday",
                    Weekday::Mon => "Monday",
                    Weekday::Tue => "Tuesday",
                    Weekday::Wed => "Wednesday",
                    Weekday::Thu => "Thursday",
                    Weekday::Fri => "Friday",
                    Weekday::Sat => "Saturday",
                };
                match day.season {
                    Season::Lent => {
                        day.description = format!(
                            "{} of the {}{} week of Lent",
                            day_string,
                            lent_counter,
                            ordinal_suffix(lent_counter),
                        );
                    }
                    Season::Advent => {
                        day.description = format!(
                            "{} of the {}{} week of Advent",
                            day_string,
                            advent_counter,
                            ordinal_suffix(advent_counter),
                        );
                    }
                    Season::Easter => {
                        day.description = format!(
                            "{} of the {}{} week of Easter",
                            day_string,
                            easter_counter,
                            ordinal_suffix(easter_counter),
                        );
                    }
                    Season::Christmas => {
                        day.description = format!("Christmas Weekday");
                    }
                    Season::OrdinaryTime => {
                        day.description = format!(
                            "{} of the {}{} week of Ordinary Time",
                            day_string,
                            ordinary_counter,
                            ordinal_suffix(ordinary_counter)
                        );
                    }
                    _ => (),
                }
            }
        }
        println!("{} - {}", day.date, day.description);
    }
}

