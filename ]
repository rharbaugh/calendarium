pub fn proper_of_seasons(today: NaiveDate) -> ChurchYear {
    let mut days: Vec<ChurchDay> = Vec::new();
    //figure out whether we wanna start with the current year's 'first sunday of advent', or last
    //year
    let mut first_advent = first_sunday_advent(today.year());
    if today < first_advent.date {
        first_advent = first_sunday_advent(today.year() - 1);
    }

    days.append(calculate_advent(&first_advent));

    let christmas = ChurchDay::new(
        first_advent.date.year(),
        12,
        25,
        DayClass::Solemnity,
        Season::Christmas,
        "The Nativity of the Lord (Christmas)",
    );

    let year = christmas.date.year() + 1;

    let epiphany = epiphany(first_advent.date.year() + 1).expect("Unable to calculate Epiphany.");
    let baptism = baptism(epiphany.clone());
    let easter = easter_for_year(year);
    let ash_wednesday = ash_wednesday(&easter);
    let pentecost = pentecost(easter.clone());
    let mut holy_week = holy_week(easter.clone());

    days.push(first_advent.clone());

    add_days_including(
        &mut days,
        first_advent.date + Duration::days(1),
        &christmas,
        Season::Advent,
        day_class,
    );

    add_days_including(
        &mut days,
        christmas.date + Duration::days(1),
        &epiphany,
        Season::Christmas,
        day_class,
    );

    add_days_including(
        &mut days,
        epiphany.date + Duration::days(1),
        &baptism,
        Season::Christmas,
        day_class,
    );

    add_days_including(
        &mut days,
        baptism.date + Duration::days(1),
        &ash_wednesday,
        Season::OrdinaryTime,
        ordinary_time_class,
    );

    add_days_until(
        &mut days,
        ash_wednesday.date + Duration::days(1),
        easter.date - Duration::days(7),
        Season::Lent,
        day_class,
    );

    days.append(&mut holy_week);
    days.push(easter.clone());

    add_days_including(
        &mut days,
        easter.date + Duration::days(1),
        &pentecost,
        Season::Easter,
        day_class,
    );

    let year_end = first_sunday_advent(first_advent.date.year() + 1);
    add_days_until(
        &mut days,
        pentecost.date + Duration::days(1),
        year_end.date,
        Season::OrdinaryTime,
        ordinary_time_class,
    );

    update_default_descriptions(&mut days);
    ChurchYear { days }
}
